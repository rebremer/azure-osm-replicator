# Local artifacts
backup/
old/
old_serverless/
*.tmp
.tmp_*
*.log
whatif.txt

# Compiled Bicep / ARM output
infra-vnet/**/*.json
infra-solution/**/*.json
!infra-vnet/**/*.bicepparam.json
!infra-solution/**/*.bicepparam.json

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Secrets
*.pem
*.key
.env
*.bicepparam.local

# Terraform — state files contain plaintext credentials (storage account
# keys, PG admin passwords, etc.). Provider binaries + lock caches also
# never belong in git.
**/terraform.tfstate
**/terraform.tfstate.*
**/.terraform/
**/.terraform.lock.hcl
**/crash.log
**/tf.log
*.tfvars.local

# Shell command logs — these typically contain real PG_ADMIN_PASSWORD,
# subscription IDs, tenant IDs, and MSI client IDs copy-pasted from
# live deploys. Never commit them.
shell_commands.txt
shell_*commands*.txt
shell_*commands*

# SSH keys for the VM
osm-vm-key
osm-vm-key.pub

prompt.txt
prompt.local.txt

data/

# Local perf-testing / one-off scripts that may contain hardcoded
# tenant/subscription/VM IPs or paths specific to the operator.
perf-*.sh
perf-*/